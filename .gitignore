# Python
__pycache__/
*.py[cod]
*.egg-info/
venv/
env/

# Env / secrets
*.local

# Auto-generated module docs — regenerate via docskill, never versioned
**/_MODULE_AUTO.md

# Scraped OpenAPI page cache + scrape logs — regenerate via dev/, never versioned.
# The merged schema JSONs themselves ARE versioned (exceptions below) so a clone can
# `python -m dev.codegen build` without re-scraping readme.io first.
dev/generated/*
!dev/generated/openapi/
dev/generated/openapi/*
!dev/generated/openapi/lzt_market.json
!dev/generated/openapi/lzt_forum.json
!dev/generated/openapi/lzt_antipublic.json

# codegen staging tree (regenerated by `python -m dev.codegen generate`)
dev/codegen/generated/

# ad-hoc probe/scratch output dumped while investigating — never versioned
**/_probe_out*.txt

# Ignore every dotfile/dotdir by default (IDE state, OS cruft, caches, .env, .venv, ...) —
# except the ones we actually track. Add a new `!.foo` line here whenever a dotfile
# needs to be committed, or it silently won't stage.
.*
!.gitattributes
!.gitignore
!.github/
!.githooks/
!.plans/
